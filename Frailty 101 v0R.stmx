			</flow>
			<flow name="net inmigration" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>migration_scaling_factor*unadjusted_migration</eqn>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<aux name="target total\nresident population">
				<doc>From Singapore census. See working in &quot;Population working.xlsx&quot;.

Current version based on parameters till 2022, needs updating.</doc>
				<eqn>0</eqn>
				<units>People</units>
			</aux>
			<aux name="migration scaling factor">
				<doc>Assumed total population is never 0.

This is a synthetic formula that accelerates the volume of migration in proportion to cube of ratio of target to actual total resident population, while the split of migration by race and gender is in line with existing population.

To be calibrated.

Version v0O:
IF TIME &lt;= 2025

THEN 1.00

ELSE</doc>
				<eqn>(target_total_resident_population/total_resident_population)^3</eqn>
				<format precision="max"/>
				<units>Dimensionless</units>
			</aux>
			<aux name="unadjusted migration">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>resident_population*net_migration_rate</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="net migration rate">
				<doc>From Singapore census. See working in &quot;Population working.xlsx&quot;.

Current version based on parameters till 2022, needs updating.</doc>
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>0</eqn>
				<units>Dimensionless/Year</units>
			</aux>
			<aux name="total migration">
				<eqn>SUM(net_inmigration)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="cohort length">
				<eqn>1</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="one by year">
				<eqn>1</eqn>
				<units>Dimensionless/Year</units>
			</aux>
		</variables>

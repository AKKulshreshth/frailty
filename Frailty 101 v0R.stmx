			<aux name="incidence rate\npre-frail to frail">
				<doc>See documentation for incidence rate robust to pre-frail</doc>
				<dimensions>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>one_by_year*(IF (age_as_a_number[age] &gt;= 50)
THEN 
(1 - (EXP(&quot;OR_pre-frail_to_frail_Alpha&quot;[gender] -&quot;OR_pre-frail_to_frail_Beta&quot;[gender]*age_as_a_number[age]) / (1 + EXP(&quot;OR_pre-frail_to_frail_Alpha&quot;[gender] - &quot;OR_pre-frail_to_frail_Beta&quot;[gender]*age_as_a_number[age])) )^(1/5))
ELSE
0)</eqn>
				<units>Dimensionless/Year</units>
			</aux>
			<stock name="pre-frail\nundiagnosed" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>resident_population*Initial_prefrailty_prevalance</eqn>
				<inflow>&quot;transition_robust_to_pre-frail&quot;</inflow>
				<inflow>&quot;ageing_in_pre-frail_undiagnosed&quot;</inflow>
				<inflow>&quot;net_inmigration_pre-frail&quot;</inflow>
				<outflow>&quot;detection_of_pre-frailty&quot;</outflow>
				<outflow>&quot;transition_pre-frail_to_frail_undiagnosed&quot;</outflow>
				<outflow>&quot;deaths_pre-frail_undiagnosed&quot;</outflow>
				<outflow>&quot;ageing_out_pre-frail_undiagnosed&quot;</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="pre-frail\ndiagnosed">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>0</eqn>
				<inflow>&quot;detection_of_pre-frailty&quot;</inflow>
				<inflow>&quot;ageing_in_pre-frail_diagnosed&quot;</inflow>
				<outflow>&quot;transition_pre-frail_to_frail_diagnosed&quot;</outflow>
				<outflow>&quot;deaths_pre-frail_diagnosed&quot;</outflow>
				<outflow>&quot;ageing_out_pre-frail_diagnosed&quot;</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="frail\nundiagnosed" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>resident_population*initial_frailty_prevalence</eqn>
				<inflow>&quot;transition_pre-frail_to_frail_undiagnosed&quot;</inflow>
				<inflow>ageing_in_frail_undiagnosed</inflow>
				<inflow>net_inmigration_frail</inflow>
				<outflow>detection_of_frailty</outflow>
				<outflow>deaths_frail_undiagnosed</outflow>
				<outflow>ageing_out_frail_undiagnosed</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="frail\ndiagnosed">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>0</eqn>
				<inflow>&quot;transition_pre-frail_to_frail_diagnosed&quot;</inflow>
				<inflow>detection_of_frailty</inflow>
				<inflow>ageing_in_frail_diagnosed</inflow>
				<outflow>deaths_frail_diagnosed</outflow>
				<outflow>ageing_out_frail_diagnosed</outflow>
				<non_negative/>
				<units>People</units>
			</stock>

	</model>
	<model name="Screening">
		<variables>
			<aux name="screening sensitivity">
				<eqn>0</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="screening specificity">
				<eqn>0</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="screening threshold age">
				<eqn>0</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="screening cap\nuniversal">
				<eqn>0</eqn>
				<units>People/Years</units>
			</aux>
			<stock name="robust\npeople" access="input">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="pre-frail\nundiagnosed" access="input">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="frail\nundiagnosed" access="input">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<non_negative/>
				<units>People</units>
			</stock>
			<aux name="age as a number" access="input">
				<dimensions>
					<dim name="age"/>
				</dimensions>
				<eqn>0</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="robust eligible\nto be screened">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>robust_people[race,gender,age]*screened_age_vector[age]*Dimensionless_year</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="pre-frail eligible\nto be screened">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>&quot;pre-frail_undiagnosed&quot;*screened_age_vector[age]*Dimensionless_year</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="frail eligible\nto be screened">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>frail_undiagnosed*screened_age_vector[age]*Dimensionless_year</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="population eligible to be screened">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>robust_eligible_to_be_screened +
frail_eligible_to_be_screened +
&quot;pre-frail_eligible_to_be_screened&quot;</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total people screened">
				<eqn>MIN(effective_screening_cap,  SUM(population_eligible_to_be_screened))</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="robust people\nscreened">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>robust_people*proportion_of_unscreened_people_screened*screened_age_vector[age]</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="pre-frail people\nscreened">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>&quot;pre-frail_undiagnosed&quot;*proportion_of_unscreened_people_screened*screened_age_vector[age]</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="frail people\nscreened">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>frail_undiagnosed*proportion_of_unscreened_people_screened*screened_age_vector[age]</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="true positives pre-frail" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>screening_sensitivity*&quot;pre-frail_people_screened&quot;</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="true positives frail" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>screening_sensitivity*frail_people_screened</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="false positives">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>(1-screening_specificity)*robust_people_screened</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="true negatives">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>screening_specificity*robust_people_screened</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="false negatives pre-frail">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>(1-screening_sensitivity)*&quot;pre-frail_people_screened&quot;</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total assessments of frail and pre-frail">
				<eqn>SUM(true_positives_frail) +
SUM(&quot;true_positives_pre-frail&quot;)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="screened age vector">
				<dimensions>
					<dim name="age"/>
				</dimensions>
				<eqn>IF age_as_a_number[age] &gt;= screening_threshold_age
THEN 1
ELSE 0</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="proportion of unscreened\npeople screened">
				<eqn>one_by_year*total_people_screened/SUM(population_eligible_to_be_screened)</eqn>
				<units>Dimensionless/Year</units>
			</aux>
			<aux name="wasted assessments">
				<eqn>SUM(false_positives)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total false negatives">
				<eqn>SUM(&quot;false_negatives_pre-frail&quot;) +
SUM(false_negatives_frail)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="false negatives frail">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>(1-screening_sensitivity)*frail_people_screened</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="frail lived years as\npercentage of total" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Dimensionless</units>
			</aux>
			<stock name="cumulative pre-frail to frail\ntransitions averted" access="input">
				<eqn>0</eqn>
				<non_negative/>
				<units>People</units>
			</stock>
			<aux name="screening cap\nopportunistic">
				<eqn>0</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="effective screening\ncap">
				<eqn>IF TIME &lt; 2027
THEN screening_cap_opportunistic
ELSE screening_cap_universal</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="Dimensionless year" access="input">
				<eqn>1</eqn>
				<units>Dimensionless/Year</units>
			</aux>
			<aux name="one by year" access="input">
				<eqn>1</eqn>
				<units>Dimensionless/Year</units>
			</aux>
		</variables>
		<views>
			<style color="black" background="white" font_style="normal" font_weight="normal" text_decoration="none" text_align="center" vertical_text_align="center" font_color="black" font_family="Arial" font_size="10pt" padding="2" border_color="black" border_width="thin" border_style="none">
				<text_box color="black" background="white" text_align="left" vertical_text_align="top" font_size="12pt"/>

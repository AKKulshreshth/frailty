			</flow>
			<aux name="fertility rate">
				<doc>From Singapore census. See working in &quot;Population working.xlsx&quot;.

Current version based on parameters till 2022, needs updating.</doc>
				<dimensions>
					<dim name="race"/>
				</dimensions>
				<eqn>0</eqn>
				<units>Dimensionless/Year</units>
			</aux>
			<aux name="fecund female population">
				<dimensions>
					<dim name="race"/>
				</dimensions>
				<element subscript="Chinese">
					<eqn>SUM(resident_population[Chinese,female,17:51])</eqn>
				</element>
				<element subscript="Malay">
					<eqn>SUM(resident_population[Malay,female,17:51])</eqn>
				</element>
				<element subscript="Indian">
					<eqn>SUM(resident_population[Indian,female,17:51])</eqn>
				</element>
				<element subscript="Other">
					<eqn>SUM(resident_population[Other,female,17:51])</eqn>
				</element>
				<units>People</units>
			</aux>
			<aux name="gender proportion\nof babies">
				<doc>From Singapore census. See working in &quot;Population working.xlsx&quot;.

Current version based on parameters till 2022, needs updating.</doc>
				<dimensions>
					<dim name="gender"/>
				</dimensions>
				<eqn>0</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="age-specific baseline\nmortality rate" access="output" isee:autocreated="true">
				<doc>From Singapore census. See working in &quot;Population working.xlsx&quot;.

Current version based on parameters till 2022, needs updating.</doc>
				<dimensions>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>0</eqn>
				<units>Dimensionless/Year</units>
			</aux>
			<aux name="total resident population">
				<eqn>SUM(resident_population)</eqn>
				<units>People</units>
			</aux>
			<aux name="total births">
				<eqn>SUM(births)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total deaths">
				<eqn>SUM(deaths)</eqn>
				<units>People/Years</units>
			</aux>
			<flow name="ageing\nout">
				<dimensions>
					<dim name="race" marked_a2a="true"/>

				<non_negative/>
				<units>People/Years</units>
			</flow>
			<flow name="net inmigration frail">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>net_inmigration*initial_frailty_prevalence</eqn>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<aux name="Age 55 plus vector">
				<dimensions>
					<dim name="age"/>
				</dimensions>
				<eqn>0</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="Total net inmigration robust">
				<eqn>SUM(net_inmigration_robust)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total net inmigration pre-frail">
				<eqn>SUM(&quot;net_inmigration_pre-frail&quot;)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total net inmigration frail">
				<eqn>SUM(net_inmigration_frail)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="deaths 1" access="input">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total deaths r">
				<eqn>SUM(deaths_robust)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total deaths pu">
				<eqn>SUM(&quot;deaths_pre-frail_undiagnosed&quot;)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total deaths pd">
				<eqn>SUM(&quot;deaths_pre-frail_diagnosed&quot;)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total deaths fu">
				<eqn>SUM(deaths_frail_diagnosed)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total death fd">
				<eqn>SUM(deaths_frail_undiagnosed)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total death res pop">
				<eqn>SUM(deaths_1)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total ageing in robust">
				<eqn>SUM(ageing_in_robust)</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="total ageing out robust">
				<eqn>SUM(ageing_out_robust)</eqn>
				<units>People/Years</units>
			</aux>
			<stock name="resident population" access="input">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>0</eqn>
				<non_negative/>
				<units>People</units>
			</stock>
			<flow name="births into robust">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>births</eqn>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<aux name="births" access="input">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="weighted frailty stock">
				<doc>For each cell of [race,gender,age]:
total_deaths_in_cell = baseline age-specific mortality rate × resident_population (1)
Also,
total_deaths_in_cell =  robust  population          × RR Robust
                     + RR_pfu × prefrail_undiagnosed   × RR Robust
                     + RR_pfd × prefrail_diagnosed     × RR Robust
                     + RR_fu × frail_undiagosed      × RR Robust
                     + RR_fd × frail_diagnosed        × RR Robust                                                               (2)

From (1) and (2):
RR Robust ×
(robust  population + RR_pfu * prefrail_undiagnosed + RR_pfd * prefrail_diagnosed + RR_fu * frail_undiagnosed + RR_fd * frail_diagnosed)
= baseline age-specific mortality rate * resident_population                                               (3)

Finally,
RR Robust = (baseline age-specific mortality rate × resident_population)
            / (robust  population + RR_pfu × prefrail_undiagnosed +  RR_pfd* prefrail_diagnosed + RR_fu * frail_undiagnosed + RR_fd * frail_diagnosed)                   (4)

weighted_frailty_stock[race, gender, age]  is the denominator part of the equation (4)
 
It is used next in the RR robust calculation</doc>
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>one_by_year*robust_people +
&quot;relative_risk_mortality_pre-frail_undiagnosed&quot;*&quot;pre-frail_undiagnosed&quot; +
&quot;relative_risk_mortality_pre-frail_diagnosed&quot;*&quot;pre-frail_diagnosed&quot;
+relative_risk_mortality_frail_undiagnosed*frail_undiagnosed
+relative_risk_mortality_frail_diagnosed*frail_diagnosed</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="relative risk\nmortality robust">
				<doc>See explanation for weighted frailty stock</doc>
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>one_by_year*Age_55_plus_vector[age]*&quot;age-specific_baseline_mortality_rate&quot;[gender,age]*resident_population_1/MAX(weighted_frailty_stock[race,gender,age], 1)</eqn>
				<units>Dimensionless/Year</units>
			</aux>
			<aux name="age-specific baseline\nmortality rate" access="input">
				<dimensions>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>0</eqn>
				<units>Dimensionless/Year</units>
			</aux>
			<aux name="deaths" access="input">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="true positives pre-frail" access="input">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="true positives frail" access="input">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>People/Years</units>
			</aux>
			<stock name="Cumulative robust\npeople years">
				<eqn>0</eqn>
				<inflow>annual_robust_people_years</inflow>
				<non_negative/>
				<units>People*Years</units>
			</stock>
			<stock name="cumulative pre-frail undiagnosed years">
				<eqn>0</eqn>
				<inflow>&quot;annual_pre-frail_un_diagnosed_people_years&quot;</inflow>
				<non_negative/>
				<units>People*Years</units>
			</stock>
			<stock name="cumulative pre-frail\ndiagnosed years">
				<eqn>0</eqn>
				<inflow>&quot;annual_pre-frail_diagnosed_years&quot;</inflow>
				<non_negative/>
				<units>People*Years</units>
			</stock>
			<stock name="cumulative frail\nundiagnosed years">
				<eqn>0</eqn>
				<inflow>annual_frail_undiagnosed_years</inflow>
				<non_negative/>
				<units>People*Years</units>
			</stock>
			<stock name="cumulative frail diagnosed years">
				<eqn>0</eqn>
				<inflow>annual_frail_diagnosed_years</inflow>
				<non_negative/>
				<units>People*Years</units>
			</stock>
			<flow name="annual robust\npeople years">
				<eqn>SUM(robust_people)</eqn>
				<non_negative/>
				<units>People</units>
			</flow>
			<flow name="annual pre-frail\nun diagnosed people years">
				<eqn>SUM(&quot;pre-frail_undiagnosed&quot;)</eqn>
				<non_negative/>
				<units>People</units>
			</flow>
			<flow name="annual pre-frail\ndiagnosed years">
				<eqn>SUM(&quot;pre-frail_diagnosed&quot;)</eqn>
				<non_negative/>
				<units>People</units>
			</flow>
			<flow name="annual frail\nundiagnosed years">
				<eqn>SUM(frail_undiagnosed)</eqn>
				<non_negative/>
				<units>People</units>
			</flow>
			<flow name="annual frail\ndiagnosed years">
				<eqn>SUM(frail_diagnosed)</eqn>
				<non_negative/>
				<units>People</units>
			</flow>
			<aux name="total lived person years">
				<eqn>Cumulative_robust_people_years + &quot;cumulative_pre-frail_undiagnosed_years&quot; + cumulative_frail_diagnosed_years + cumulative_frail_undiagnosed_years + &quot;cumulative_pre-frail_diagnosed_years&quot;</eqn>
				<units>People*Years</units>
			</aux>
			<aux name="frail lived person years">
				<eqn>cumulative_frail_undiagnosed_years + cumulative_frail_diagnosed_years</eqn>
				<units>People*Years</units>
			</aux>
			<aux name="frail lived years as\npercentage of total" access="output" isee:autocreated="true">
				<eqn>100*frail_lived_person_years/total_lived_person_years</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="transitions averted">
				<dimensions>
					<dim name="race"/>
					<dim name="gender"/>
					<dim name="age"/>
				</dimensions>
				<eqn>&quot;pre-frail_diagnosed&quot;*&quot;incidence_rate_pre-frail_to_frail&quot;[gender,age]*(1-Effect_of_better_care_after_diagnosis)</eqn>
				<units>People/Years</units>
			</aux>
			<stock name="cumulative pre-frail to frail\ntransitions averted" access="output" isee:autocreated="true">
				<eqn>0</eqn>
				<inflow>&quot;total_pre-frail_to_frail_transitions_averted&quot;</inflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<flow name="total pre-frail to frail transitions averted">
				<eqn>SUM(transitions_averted)</eqn>
				<non_negative/>
				<units>People/Years</units>
			</flow>
			<aux name="one by year" access="output" isee:autocreated="true">
				<eqn>1</eqn>
				<units>Dimensionless/Year</units>
			</aux>
		</variables>
